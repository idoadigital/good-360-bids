# ============================================================
# Harden-good360-monitor — secrets template
# ============================================================
# Copy to `.env` and fill real values. `.env` is gitignored.
#
# IMPORTANT (PCI): storing CVV after authorization violates PCI-DSS.
# Long-term, move card data to a tokenizing payment processor or
# a secrets manager (AWS Secrets Manager / 1Password / Vault).
# `.env` is a pragmatic stopgap, not a final answer.
# ============================================================

# ---------- Good360 accounts ----------
GOOD360_REVIVING_HOMES_EMAIL=
GOOD360_REVIVING_HOMES_PASSWORD=

GOOD360_HOPE4HUMANITY_EMAIL=
GOOD360_HOPE4HUMANITY_PASSWORD=

# ---------- Payment cards (rotate any card previously in git history) ----------
# Reviving Homes
CARD_REVIVING_HOMES_NAME=
CARD_REVIVING_HOMES_NUMBER=
CARD_REVIVING_HOMES_EXPIRY=   # MMYY
CARD_REVIVING_HOMES_CVV=
CARD_REVIVING_HOMES_TYPE=visa

# Hope 4 Humanity
CARD_HOPE4HUMANITY_NAME=
CARD_HOPE4HUMANITY_NUMBER=
CARD_HOPE4HUMANITY_EXPIRY=
CARD_HOPE4HUMANITY_CVV=
CARD_HOPE4HUMANITY_TYPE=visa

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_REVIVING_HOMES=
TELEGRAM_GROUP_HOPE4HUMANITY=
TELEGRAM_OPERATOR_CHAT_ID=   # operator's personal chat for intake-form submissions

# ---------- Email / alert channels ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=               # Gmail app password — rotate any value previously in git
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ---------- Mission Control API ----------
MISSIONCONTROL_API_KEY=      # rotate any value previously in git history

# ---------- Runtime ----------
WORKDIR=/a0/usr/workdir
TZ=America/New_York
LOG_LEVEL=INFO

# ---------- Environment feature flags (multi-env workflow) ----------
# Read ONLY from the environment (never from the dashboard settings DB).
# Unset = enabled, so production needs no change. Staging and feature
# environments MUST set both to false — see WORKFLOW.md.
#   ENABLE_AUTO_BUY=false     -> every purchase path refuses to run
#                                (monitor run_autobuy, daemon /checkout +
#                                /test_checkout + /live/* purchase endpoints,
#                                good360_autobuy.py, autobuy_v2.attempt_purchase)
#   ENABLE_URL_SCANNING=false -> monitor scan loop idles; no Good360 requests
ENABLE_AUTO_BUY=true
ENABLE_URL_SCANNING=true

# Multi-env plumbing (set per checkout; see WORKFLOW.md):
#   COMPOSE_PROJECT_NAME=good-360-bids            # -staging / -feature
#   DASHBOARD_PROJECT_DIR=/root/good-360-bids     # -staging / -feature
#   MISSIONCONTROL_URL=http://missioncontrol:5001          # service name differs per env
#   MISSIONCONTROL_INTERNAL_URL=http://missioncontrol:5001

# ---------- Optional Chrome DevTools MCP checkout agent ----------
# Default is the existing daemon/script checkout path. Set to devtools_agent
# only after staging dry-runs against the live Good360 checkout flow.
AUTOBUY_ENGINE=daemon
OPENAI_API_KEY=
DEVTOOLS_AGENT_MODEL=gpt-5.1
DEVTOOLS_AGENT_DRY_RUN=true
DEVTOOLS_AGENT_TIMEOUT_SECONDS=420
DEVTOOLS_AGENT_ISOLATED=true
DEVTOOLS_AGENT_FALLBACK_ON_FAILED=false
DEVTOOLS_CHROME_EXECUTABLE=/usr/bin/google-chrome-stable

# Live purchase requires BOTH flags below. This is deliberate: the agent must
# receive checkout secrets to type them through Chrome, and it can click Place
# Order when enabled.
DEVTOOLS_AGENT_ALLOW_SECRETS_TO_MODEL=false
DEVTOOLS_AGENT_ALLOW_LIVE_PURCHASE=false

# ---------- Sandbox mode ----------
# When SANDBOX_MODE=true, every URL/credential/card the scan + autobuy stack
# uses is swapped to the test site (default https://sandbox-360.netlify.app).
# Lets us exercise the full pipeline end-to-end without ever hitting live
# Good360. Toggle from the dashboard's Settings tab; it survives container
# restarts because it lives in the encrypted settings store.
SANDBOX_MODE=false
SANDBOX_GOOD360_BASE_URL=https://sandbox-360.netlify.app
SANDBOX_GOOD360_EMAIL=
SANDBOX_GOOD360_PASSWORD=
SANDBOX_CARD_NAME=
SANDBOX_CARD_NUMBER=
SANDBOX_CARD_EXPIRY=
SANDBOX_CARD_CVV=
SANDBOX_CARD_TYPE=visa
