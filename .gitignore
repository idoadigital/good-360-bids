good360_heartbeat.json
good360_alerted_state.json
good360_watchdog_state.json
good360_daemon_state.json
good360_org_status_*.json
activity_log.json

# All logs
*.log

# PID files
*.pid

# Pause flags
*.flag

# === ARTIFACTS THAT SHOULD NEVER BE COMMITTED ===
# Screenshots
*.png
*.jpg
*.jpeg
checkout_screenshots/

# Backup / duplicate / broken files
*.bak
*.bak_*
*_old.py
*_fixed.py
*_backup.py
*_backup_*.py
*.broken*
*.corrupted*
*.backup_*

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Backups / builds
backups/
build/
dist/
*.egg-info/

# Intake submissions (PII, card data)
intake_form/submissions/
intake_form/review_queue.json

# Roster per-org configs (credentials, card data)
good360_roster/config_*.json

# Database
db/
*.db
*.sqlite
*.sqlite3

